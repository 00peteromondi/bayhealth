DJANGO_ENV=development
DJANGO_SECRET_KEY=replace-with-secure-secret
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000
DJANGO_SECURE_SSL_REDIRECT=false
DJANGO_LOG_LEVEL=INFO

# App base URL
SITE_URL=http://localhost:8000

# Database
# Option 1: SQLite for local development
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3

# Option 2: PostgreSQL / Railway
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
# PGDATABASE=bayafya_db
# PGUSER=postgres
# PGPASSWORD=
# PGHOST=localhost
# PGPORT=5432
# DB_SSLMODE=require
# DB_CONN_MAX_AGE=600

# Realtime / websockets
REDIS_URL=redis://127.0.0.1:6379/0
USE_REDIS_CHANNELS=false

# Email / Brevo
DEFAULT_FROM_EMAIL=BayAfya <00peteromondi@gmail.com>
BREVO_API_KEY=
BREVO_SENDER_EMAIL=00peteromondi@gmail.com
BREVO_SENDER_NAME=BayAfya
EMAIL_FAIL_SILENTLY=true

# AI
GOOGLE_AI_API_KEY=
GOOGLE_AI_MODEL=gemini-3-flash-preview
